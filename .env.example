# All env vars use the NOODLY_ prefix (pydantic-settings)

# OpenAI API key (required for entity extraction and embeddings)
NOODLY_OPENAI_API_KEY=sk-...
NOODLY_OPENAI_MODEL=gpt-4o-mini

# FalkorDB connection
NOODLY_FALKORDB_HOST=localhost
NOODLY_FALKORDB_PORT=6379

# Paths
NOODLY_BRAIN_DIR=./brain
NOODLY_WATCH_DIR=./inbox
